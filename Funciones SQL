--TABLAS A TRABAJAR
SELECT * FROM CLIENTE;
SELECT * FROM CREDITO_CLIENTE; 

--CONSULTA CASO 02: 

SELECT 
    TO_CHAR(CLI.NUMRUN, '999G999G999') || ' ' || CLI.DVRUN AS "RUN CLIENTE",
    UPPER(CLI.PNOMBRE || ' ' || CLI.SNOMBRE ||' '||CLI.APPATERNO||' '||CLI.APMATERNO) AS "NOMBRE CLIENTE",
    TO_CHAR(SUM(CRE.MONTO_SOLICITADO), '$999G999G999') AS "MONTO TOTAL SOLICITADOS",
    TO_CHAR(((SUM(CRE.MONTO_SOLICITADO)/100000)*1200), '$999G999G999') AS "PESOS TODOSUMA",
    EXTRACT(YEAR FROM CRE.FECHA_SOLIC_CRED) AS "AÑO SOLICITUD CREDITO"
FROM
    CLIENTE CLI JOIN CREDITO_CLIENTE CRE
    ON(CLI.NRO_CLIENTE = CRE.NRO_CLIENTE)
WHERE
    EXTRACT(YEAR FROM CRE.FECHA_SOLIC_CRED) = EXTRACT(YEAR FROM SYSDATE) - 1
GROUP BY
    CLI.NUMRUN,CLI.DVRUN,CLI.PNOMBRE,CLI.SNOMBRE,CLI.APPATERNO,CLI.APMATERNO;

