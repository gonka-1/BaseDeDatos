--TABLA A TRABAJAR--

SELECT * FROM ALUMNO;

--CONSULTA CASO 01--

SELECT 
    CARRERAID AS "IDENTIFIFCACION DE LA CARRERA",
    COUNT(*) AS "TOTAL ALUMNOS MATRICULADOS",
    'le corresponde ' ||TO_CHAR(COUNT(*)*&&INGRESAR_VALOR, '$999G999')||' del presupuesto total asignado por publicidad' AS "MONTO POR PUBLICIDAD"
FROM 
    ALUMNO
GROUP BY 
    CARRERAID
ORDER BY 
    COUNT(*) DESC;


--ELIMINAR EL VALOR PARAMETRICO INGRESADO
UNDEFINE INGRESAR_VALOR;

-----------------CASO 2-----------------

--TABLA A TRABAJAR--

SELECT * FROM ALUMNO;

--CONSULTA CASO 2--

SELECT 
    CARRERAID AS "CARRERA",
    COUNT(*) AS "TOTAL DE ALUMNOS"
FROM 
    ALUMNO
WHERE
    CARRERAID IN (340,260,150,190)
HAVING 
    COUNT(*) > &INGRESAR_CANTIDAD_FILTRO
GROUP BY
    CARRERAID
ORDER BY
    CARRERAID;

--HAVING = SE UTILIZA PARA REALIZAR FILTROS EN LOS GRUPOS, SE PUEDE ULTILIZAR CON "WHERE"

--COMANDOS DE AGRUPACIÓN

--SUM = SUMA TODOS LOS VALORES DE UN GRUPO DE DATOS
--MIN = MUESTRA EL VALOR MINIMO DE UN GRUPO DE DATOS
--MAX = MUESTRA EL VALOR MAXIMO DE UN GRUPO DE DATOS
--COUNT = CUENTA LA CANTIDAD DE DATOS O FILAS
--AVG = SACA EL PROMEDIO DE UN GRUPO DE DATOS

--GROUP BY = SIRVE PARA AGRUPAR TODAS LAS COLUMNAS QUE NO POSEEN UN COMANDO DE AGRUPACIÓN


