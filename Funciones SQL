--TABLAS A TRABAJAR
SELECT * FROM CLIENTE;
SELECT * FROM PROFESION_OFICIO

--CONSULTA CASO 01:

SELECT 
    TO_CHAR(CLI.NUMRUN, '999G999G999') || '-' || CLI.DVRUN AS "RUN CLIENTE",
    INITCAP(CLI.PNOMBRE || ' ' || CLI.SNOMBRE || ' ' || CLI.APPATERNO || ' ' || CLI.APMATERNO) AS "NOMBRE CLIENTE",
    PRO.NOMBRE_PROF_OFIC AS "PROFESION/OFIC",
    TO_CHAR(CLI.FECHA_NACIMIENTO, 'DD" de "Month') AS "FECHA CUMPLEAÑOS"
FROM
    CLIENTE CLI JOIN PROFESION_OFICIO PRO
    ON(CLI.COD_PROF_OFIC = PRO.COD_PROF_OFIC)
WHERE 
    EXTRACT(MONTH FROM CLI.FECHA_NACIMIENTO) >= EXTRACT(MONTH FROM SYSDATE) + 1
ORDER BY 
    EXTRACT(MONTH FROM CLI.FECHA_NACIMIENTO),EXTRACT(DAY FROM CLI.FECHA_NACIMIENTO),CLI.APPATERNO;
    

--EL 'CLI' Y 'PRO' EN EL CÓDIGO SE UTILIZA PARA DARLE UN PREFIJO A LA TABLA, SE UTILIZA CUANDO HAY ATRIBUTOS SIMILARES EN DOS O MÁS TABLAS.

--EL 'EXTRACT(MONTH FROM)' SE UTILIZA PARA SACAR LOS VALORES TANTO DE MES COMO DEL ANIO PARA HACER COMPARATIVA CON 'EXTRACT(MONTH FROM SYSDATE)'


