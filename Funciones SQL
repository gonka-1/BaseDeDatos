SELECT * FROM EMPLEADO;

-------------------------------------------------
--CONSULTA CASO 03:
-------------------------------------------------

SELECT
    TO_CHAR(RUN_JEFE, '09G999G999') AS "RUN JEFE SIN DV",
    COUNT(*) AS "TOTAL DE EMPLEADOS A SU CARGO",
