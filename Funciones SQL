--CASO 05 

--TABLA A TRABAJAR:

SELECT * FROM TITULO;
SELECT * FROM PRESTAMO;

-------------------------------------------------
--CONSULTA CASO 05:
-------------------------------------------------

SELECT
    t.TITULOID AS "CODIGO DEL LIBRO",
    COUNT(p.TITULOID) AS "TOTAL DE VECES SOLICITADO",
CASE
    WHEN COUNT(p.TITULOID) > 5 THEN 'SE REQUIERE COMPRAR 4 NUEVOS EJEMPLARES'
    WHEN COUNT(p.TITULOID) BETWEEN 4 AND 5 THEN 'SE REQUIERE COMPRAR 2 NUEVOS EJEMPLARES'
    WHEN COUNT(p.TITULOID) BETWEEN 2 AND 3 THEN 'SE REQUIERE COMPRAR 1 NUEVOS EJEMPLARES'
    ELSE 'NO SE REQUIERE COMPRAR NUEVOS EJEMPLARES'
END AS "SUGERENCIA"
FROM 
    TITULO t JOIN PRESTAMO p
    ON(t.TITULOID = p.TITULOID)
GROUP BY
    t.TITULOID
ORDER BY
    "TOTAL DE VECES SOLICITADO" DESC;

--CASO 06

--TABLA A TRABAJAR:

SELECT * FROM EMPLEADO;
SELECT * FROM PRESTAMO;

-------------------------------------------------
--CONSULTA CASO 06:
-------------------------------------------------

SELECT 
    TO_CHAR(e.RUN_EMP, '09G999G999') AS "RUN EMPLEADO",
    TO_CHAR(p.FECHA_INI_PRESTAMO, 'MM/YYYY') AS "MES PRESTAMOS LIBROS",
    COUNT(p.PRESTAMOID) AS "TOTAL DE PRESTAMOS ATENDIDOS",
TO_CHAR(CASE    
    WHEN COUNT(p.PRESTAMOID) > 2 THEN COUNT(p.PRESTAMOID) * 10000
    ELSE 0
END, '$999G999G999') AS "ASIGNACION POR PRESTAMOS"
FROM
    EMPLEADO e JOIN PRESTAMO p
    ON(e.RUN_EMP = p.RUN_EMP)
WHERE
    EXTRACT(YEAR FROM p.FECHA_INI_PRESTAMO) = EXTRACT(YEAR FROM SYSDATE) - 1
GROUP BY
    e.RUN_EMP, TO_CHAR(p.FECHA_INI_PRESTAMO, 'MM/YYYY')
HAVING
    COUNT(p.PRESTAMOID) > 2
ORDER BY 
    "MES PRESTAMOS LIBROS" ASC, "RUN EMPLEADO" DESC;



