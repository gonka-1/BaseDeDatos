SELECT 
    TO_CHAR(cc.FECHA_SOLIC_CRED, 'MM/YYYY') AS "MES TRANSACCIÓN",
    c.NOMBRE_CREDITO AS "TIPO CRÉDITO",
    TO_CHAR(cc.MONTO_SOLICITADO, '$999G999G999') AS "MONTO SOLICITADO CREDITO",
    CASE
        WHEN cc.MONTO_CREDITO BETWEEN 100000 AND 1000000 THEN TO_CHAR(cc.MONTO_CREDITO * 0.01, '$999G999G999')
        WHEN cc.MONTO_CREDITO BETWEEN 1000001 AND 2000000 THEN TO_CHAR(cc.MONTO_CREDITO * 0.02, '$999G999G999')
        WHEN cc.MONTO_CREDITO BETWEEN 2000001 AND 4000000 THEN TO_CHAR(cc.MONTO_CREDITO * 0.03, '$999G999G999')
        WHEN cc.MONTO_CREDITO BETWEEN 4000001 AND 6000000 THEN TO_CHAR(cc.MONTO_CREDITO * 0.04, '$999G999G999')
        WHEN cc.MONTO_CREDITO > 6000000 THEN TO_CHAR(cc.MONTO_CREDITO * 0.07, '$999G999G999')
    END AS "APORTE A LA SBIF"
FROM
    CREDITO_CLIENTE cc JOIN CREDITO c
    ON cc.COD_CREDITO = c.COD_CREDITO
ORDER BY
    cc.FECHA_SOLIC_CRED ASC, "TIPO CRÉDITO" ASC;

