---------------------------------------------------------------------------------
--HOJA DE TRABAJO DE PL/SQL
---------------------------------------------------------------------------------
---------------------------------------------------------------------------------
--CASO 01:
---------------------------------------------------------------------------------

--***DECLARACIÓN DE VARIABLES***

DECLARE
--***DECLARACIÓN DE VARIABLES***
V_NUMRUT           EMPLEADO.NUMRUT_EMP%TYPE; --NUMBER(10)
V_DVRUT            EMPLEADO.DVRUT_EMP%TYPE;
V_NOMBRE           EMPLEADO.NOMBRE_EMP%TYPE;
V_APPATERNO        EMPLEADO.APPATERNO_EMP%TYPE;
V_APMATERNO        EMPLEADO.APMATERNO_EMP%TYPE;
V_SUELDO           EMPLEADO.SUELDO_EMP%TYPE;
V_BONIF_EXTRA      NUMBER(12);
V_POR_BONIF        NUMBER(3);

BEGIN
    
    --INGRESOS PARAMETRICOS
    V_POR_BONIF     := &ingresar_bono;
    V_NUMRUT        := &ingresar_rut;
    
    --LA LINEA SIEMPRE DA ERROR EN LA VARIABLE.
    --UNDEFINE ingresar_bono;
    
    --CONSULTAR DATOS DE RUT INGRESADO
    
    SELECT 
        DVRUT_EMP,NOMBRE_EMP,APPATERNO_EMP,APMATERNO_EMP, SUELDO_EMP 
    INTO
        V_DVRUT, V_NOMBRE, V_APPATERNO,V_APMATERNO,V_SUELDO
    FROM    
        EMPLEADO
    WHERE 
        NUMRUT_EMP = V_NUMRUT;
        
    --CALCULO DE BONIFICACIÓN
    V_BONIF_EXTRA := V_SUELDO * (V_POR_BONIF/100);
    
    --IMPRESIONES POR TERMINAL
    DBMS_OUTPUT.PUT_LINE('-------------------------------------------------------');
    DBMS_OUTPUT.PUT_LINE('DATOS DE CALCULO DE BONIFICACIÓN EXTRA DE'||V_POR_BONIF||'% DEL SUELDO');
    DBMS_OUTPUT.PUT_LINE('-------------------------------------------------------');
    DBMS_OUTPUT.PUT_LINE('NOMBRE EMPLEADO: '||V_NOMBRE||' '||V_APPATERNO||' '||V_APMATERNO);
    DBMS_OUTPUT.PUT_LINE('RUT EMPLEADO:'||TO_CHAR(V_NUMRUT, '999G999G999')||'-'||V_DVRUT);
    DBMS_OUTPUT.PUT_LINE('SUELDO EMPLEADO: '||TO_CHAR(V_SUELDO, '$999G999G999'));
    DBMS_OUTPUT.PUT_LINE('BONIFICACIÓN EXTRA: '||TO_CHAR(V_BONIF_EXTRA, '$999G999G999'));
    DBMS_OUTPUT.PUT_LINE('-------------------------------------------------------');
    DBMS_OUTPUT.PUT_LINE(' ');
    
    
END; 

/

--SEPARACIÓN DE BLOQUE ANONIMO

---------------------------------------------------------------------------------
--CASO 02:
---------------------------------------------------------------------------------

DECLARE
    --DECLARACIÓN DE VARIABLES
    V_NUMRUT                CLIENTE.NUMRUT_CLI%TYPE;
    V_DVRUT                 CLIENTE.DVRUT_CLI%TYPE;
    V_NOMBRE                CLIENTE.NOMBRE_CLI%TYPE;
    V_APPATERNO             CLIENTE.APPATERNO_CLI%TYPE;
    V_APMATERNO             CLIENTE.APMATERNO_CLI%TYPE;
    V_RENTA                 CLIENTE.RENTA_CLI%TYPE;
    V_DESC_CIVIL            ESTADO_CIVIL.DESC_ESTCIVIL%TYPE;
    V_CUMPLE_REQUISITOS     BOOLEAN := FALSE;
    V_RENTA_MINIMA          NUMBER(10) := 800000;
    
BEGIN
    --INGRESO PARAMETRICO:
    
    V_NUMRUT := &INGRESAR_RUT;
    
    SELECT 
        CLI.DVRUT_CLI, CLI.NOMBRE_CLI, CLI.APPATERNO_CLI, CLI.APMATERNO_CLI,
        CLI.RENTA_CLI, EC.DESC_ESTCIVIL
    INTO
        V_DVRUT, V_NOMBRE, V_APPATERNO, V_APMATERNO, V_RENTA, V_DESC_CIVIL
    FROM
        CLIENTE CLI JOIN ESTADO_CIVIL EC
        ON(CLI.ID_ESTCIVIL = EC.ID_ESTCIVIL)
    WHERE
        CLI.NUMRUT_CLI = V_NUMRUT;
        
        
    --CONDICIONES IF:
    
    IF V_DESC_CIVIL IN ('Soltero', 'Separado', 'Divorciado') THEN
        --PASA SI ES SEPARADO, SOLTERO O DIVORCIADO
        IF V_DESC_CIVIL IN ('Separado', 'Divorciado') THEN
        --PASA SI ES SEPARADO O DIVORCIADO
            IF V_RENTA >= V_RENTA_MINIMA THEN
            --PASA SI ES SEPARADO O DIVORCIADO Y CUMPLE UNA RENTA DE 800MIL
                V_CUMPLE_REQUISITOS := TRUE;
            END IF;--SIEMPRE QUE SE INICIA UN "IF" SE TIENE QUE CERRAR CON UN "END IF".
        ELSE
            --PASA SI ES SOLTERO
            V_CUMPLE_REQUISITOS := TRUE;
        END IF;
    END IF;
    
    IF V_CUMPLE_REQUISITOS THEN
        DBMS_OUTPUT.PUT_LINE('---------------------------------------------------');
        DBMS_OUTPUT.PUT_LINE('DATOS DE CLIENTE');
        DBMS_OUTPUT.PUT_LINE('---------------------------------------------------');
        DBMS_OUTPUT.PUT_LINE('RUT CLIENTE: '||TO_CHAR(V_NUMRUT, '999G999G999')||'-'||V_DVRUT);
        DBMS_OUTPUT.PUT_LINE('NOMBRE CLIENTE: '||V_NOMBRE||' '||V_APPATERNO||' '||V_APMATERNO);
        DBMS_OUTPUT.PUT_LINE('ESTADO CIVIL: '||V_DESC_CIVIL);
        DBMS_OUTPUT.PUT_LINE('RENTA CLIENTE: '||TO_CHAR(V_RENTA, '$999G999G999'));
        DBMS_OUTPUT.PUT_LINE('---------------------------------------------------');
        DBMS_OUTPUT.PUT_LINE('CUMPLE CON LOS REQUISITOS DER LA PROMOCION DE MARKETING');
    ELSE
        DBMS_OUTPUT.PUT_LINE('NO CUMPLE CON LOS REQUISITOS DE LA PROMOCION DE MARKETING.');
    END IF;
--TRY CATCH DE PL/SQL

EXCEPTION 
    WHEN NO_DATA_FOUND THEN 
         DBMS_OUTPUT.PUT_LINE('NO SE HA ENCONTRADO EL RUT INGRESADO EN LA BASE DE DATOS');
    WHEN OTHERS THEN
          DBMS_OUTPUT.PUT_LINE('HA OCURRIDO UN ERROR INESPERADO');
           DBMS_OUTPUT.PUT_LINE('CODIGO DE ERROR: '||SQLERRM);
        

END;

/


