--***DECLARACIÓN DE VARIABLES***

DECLARE
--***DECLARACIÓN DE VARIABLES***
V_NUMRUT           EMPLEADO.NUMRUT_EMP%TYPE; --NUMBER(10)
V_DVRUT            EMPLEADO.DVRUT_EMP%TYPE;
V_NOMBRE           EMPLEADO.NOMBRE_EMP%TYPE;
V_APPATERNO        EMPLEADO.APPATERNO_EMP%TYPE;
V_APMATERNO        EMPLEADO.APMATERNO_EMP%TYPE;
V_SUELDO           EMPLEADO.SUELDO_EMP%TYPE;
V_BONIF_EXTRA      NUMBER(12);
V_POR_BONIF        NUMBER(3);

BEGIN
    
    --INGRESOS PARAMETRICOS
    V_POR_BONIF     := &ingresar_bono;
    V_NUMRUT        := &ingresar_rut;
    
    --LA LINEA SIEMPRE DA ERROR EN LA VARIABLE.
    --UNDEFINE ingresar_bono;
    
    --CONSULTAR DATOS DE RUT INGRESADO
    
    SELECT 
        DVRUT_EMP,NOMBRE_EMP,APPATERNO_EMP,APMATERNO_EMP, SUELDO_EMP 
    INTO
        V_DVRUT, V_NOMBRE, V_APPATERNO,V_APMATERNO,V_SUELDO
    FROM    
        EMPLEADO
    WHERE 
        NUMRUT_EMP = V_NUMRUT;
        
    --CALCULO DE BONIFICACIÓN
    V_BONIF_EXTRA := V_SUELDO * (V_POR_BONIF/100);
    
    --IMPRESIONES POR TERMINAL
    DBMS_OUTPUT.PUT_LINE('-------------------------------------------------------');
    DBMS_OUTPUT.PUT_LINE('DATOS DE CALCULO DE BONIFICACIÓN EXTRA DE'||V_POR_BONIF||'% DEL SUELDO');
    DBMS_OUTPUT.PUT_LINE('-------------------------------------------------------');
    DBMS_OUTPUT.PUT_LINE('NOMBRE EMPLEADO: '||V_NOMBRE||' '||V_APPATERNO||' '||V_APMATERNO);
    DBMS_OUTPUT.PUT_LINE('RUT EMPLEADO:'||TO_CHAR(V_NUMRUT, '999G999G999')||'-'||V_DVRUT);
    DBMS_OUTPUT.PUT_LINE('SUELDO EMPLEADO: '||TO_CHAR(V_SUELDO, '$999G999G999'));
    DBMS_OUTPUT.PUT_LINE('BONIFICACIÓN EXTRA: '||TO_CHAR(V_BONIF_EXTRA, '$999G999G999'));
    DBMS_OUTPUT.PUT_LINE('-------------------------------------------------------');
    DBMS_OUTPUT.PUT_LINE(' ');
    
    
END; 

/

