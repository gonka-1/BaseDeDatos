--TABLAS A TRABAJAR:

SELECT * FROM CAMION; --CA
SELECT * FROM TRACTO_CAMION; --TC
SELECT * FROM GUARDIA; --GU
SELECT * FROM COMUNA; --CO


--CONSULTA CASO 05:

SELECT 
    CA.PATENTE_CAMION AS "PATENTE CAMION",
    CA.MARCA_CAMION AS "MARCA CAMION",
    CA.MODELO_CAMION AS "MODELO CAMION",
    TC.PATENTE_TRACTO_CAMION AS "PATENTE TRACTO CAMION",
    TC.MARCA_TRACTO_CAMION AS "MARCA TRACTO CAMION"
FROM 
    CAMION CA JOIN TRACTO_CAMION TC 
    ON (CA.PATENTE_CAMION = TC.PATENTE_CAMION)
    JOIN GUARDIA GU ON(CA.ID_GUARDIA = GU.ID_GUARDIA)
    JOIN COMUNA CO ON (GU.ID_COMUNA = CO.ID_COMUNA)
WHERE
    (GU.ID_GUARDIA IN (SELECT ID_GUARDIA FROM GUARDIA WHERE ID_COMUNA = (SELECT ID_COMUNA 
                                                                        FROM COMUNA 
                                                                        WHERE NOMBRE_COMUNA='ANTOFAGASTA')))
    AND(EXTRACT(YEAR FROM GU.FECHA_CONTRATO_GUARDIA) > 2015)
;

