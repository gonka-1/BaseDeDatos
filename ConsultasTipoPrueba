--TABLAS A TRABAJAR: 

SELECT * FROM COMUNA;
SELECT * FROM RECINTO;
SELECT * FROM EMPRESA_CLIENTE;

SELECT 
    EC.NOMBRE_EMPRESA AS "ZONA TNT",
    C.NOMBRE_COMUNA AS "COMUNA",
    CASE
        WHEN COUNT(*) = 1 THEN 'UNICO'
        WHEN COUNT(*) >= 2 THEN 'Múltiple'
    END AS "CATEGORIA RECINTO",
    COUNT(*) AS "TOTAL DE RECINTOS"
FROM 
    EMPRESA_CLIENTE EC JOIN RECINTO R 
    ON(EC.ID_EMPRESA = R.ID_EMPRESA)
    JOIN COMUNA C 
    ON (R.ID_COMUNA = C.ID_COMUNA)
GROUP BY 
    EC.NOMBRE_EMPRESA, C.NOMBRE_COMUNA
ORDER BY 
    EC.NOMBRE_EMPRESA DESC
;

