--TABLAS A TRABAJAR:

SELECT * FROM GUARDIA;

--CONSULTA 01:


SELECT 
    CASE 
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA) / 12) < 20 THEN 'Menor a 20 anios'
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA) / 12) BETWEEN 21 AND 30 THEN 'Entre 21 y 30'
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA) / 12) BETWEEN 31 AND 40 THEN 'Entre 31 y 40'
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA) / 12) BETWEEN 41 AND 50 THEN 'Entre 41 y 50'
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA) / 12) > 51 THEN '51 O Más'
    END AS "RANGO EDAD",
    COUNT(*) AS "CANTIDAD DE GUARDIAS"
    FROM GUARDIA
    GROUP BY
    CASE 
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA) / 12) < 20 THEN 'Menor a 20 anios'
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA) / 12) BETWEEN 21 AND 30 THEN 'Entre 21 y 30'
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA) / 12) BETWEEN 31 AND 40 THEN 'Entre 31 y 40'
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA) / 12) BETWEEN 41 AND 50 THEN 'Entre 41 y 50'
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA) / 12) > 51 THEN '51 O Más'
    END
    ORDER BY 1 ASC;


