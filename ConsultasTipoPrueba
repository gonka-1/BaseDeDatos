--TABLA A TRABAJAR:

SELECT * FROM GUARDIA
SELECT * FROM RECINTO;

--CONSULTA 02:

SELECT 
    G.ID_GUARDIA AS "CODIGO GUARDIA",
    G.PNOMBRE_GUARDIA || ' ' || G.SNOMBRE_GUARDIA || ' ' || G.APPATERNO_GUARDIA || ' ' || G.APMATERNO_GUARDIA AS "NOMBRE COMPLETO GUARDIA",
    TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA) / 12) AS "EDAD",
    TO_CHAR(ADD_MONTHS(FECHA_NAC_GUARDIA, 65*12), 'DD-MM-YYYY') AS "FECHA DE JUBILACIÓN",
    R.NOMBRE_RECINTO AS "NOMBRE RECINTO"
FROM 
    GUARDIA G JOIN RECINTO R
    ON(G.ID_RECINTO = R.ID_RECINTO)
ORDER BY 
    "EDAD" DESC;
    
